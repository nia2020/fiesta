// 学園祭実行委員会サイト - データベーススキーマ
// 本番: PostgreSQL (Vercel Postgres / Neon 等)
// 開発: DATABASE_URL に postgresql:// を指定

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name          String?
  role          Role     @default(MEMBER)
  profileImage  String?
  bio           String?
  department    String?
  snsLinks      String? // JSON: { twitter, instagram, etc }
  contactPublic Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  chairpersons     Chairperson[]
  committeeMembers CommitteeMember[]
  universityRoles  UniversityRole[]
}

enum Role {
  VIEWER
  MEMBER
  EXECUTIVE
  CHAIRPERSON
  SYSTEM_ADMIN
}

model University {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  logoUrl       String?
  coverImageUrl String? // カード表示用の画像（新着大学セクションなど）
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  festivals        Festival[]
  universityRoles  UniversityRole[]
  committeeMembers CommitteeMember[]
}

model Festival {
  id           String   @id @default(cuid())
  universityId String
  year         Int
  status       String   @default("draft") // draft, published, archived
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  university         University          @relation(fields: [universityId], references: [id], onDelete: Cascade)
  chairperson        Chairperson?
  theme              Theme?
  sponsorPlans       SponsorPlan[]
  festivalHighlights FestivalHighlight[]
}

model FestivalHighlight {
  id           String   @id @default(cuid())
  festivalId   String
  title        String
  description  String?
  imageUrl     String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  festival Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
}

model Chairperson {
  id              String    @id @default(cuid())
  festivalId      String    @unique
  userId          String
  predecessorId   String?
  handoverDate    DateTime?
  handoverComment String?
  message         String?
  displayOrder    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  festival    Festival      @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  predecessor Chairperson?  @relation("Succession", fields: [predecessorId], references: [id])
  successors  Chairperson[] @relation("Succession")
}

model Theme {
  id           String    @id @default(cuid())
  festivalId   String    @unique
  themeName    String
  eventDate    DateTime?
  eventEndDate DateTime?
  venue        String?
  schedule     String? // JSON or markdown
  details      String?
  accessInfo   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  festival Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
}

model SponsorPlan {
  id           String   @id @default(cuid())
  festivalId   String
  planName     String
  amount       Int // 協賛金額（円）
  benefits     String? // 特典説明（markdown可）
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  festival Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
}

model CommitteeMember {
  id           String   @id @default(cuid())
  userId       String
  universityId String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId])
}

model UniversityRole {
  id           String   @id @default(cuid())
  userId       String
  universityId String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId])
}

// 学祭がくれたもの - 取材オファー（招待制）
model GakusaiInterviewOffer {
  id              String    @id @default(cuid())
  inviteToken     String    @unique
  chairpersonName String
  university      String
  year            Int
  status          String    @default("pending") // pending, in_progress, completed
  conversation    String? // JSON: [{ role: "ai"|"user", content: string }]
  articleId       String?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// 学祭がくれたもの - AI取材記事
model GakusaiArticle {
  id              String    @id @default(cuid())
  title           String
  excerpt         String
  chairpersonName String
  university      String
  year            Int
  thumbnailUrl    String
  status          String    @default("draft") // draft, published
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sections GakusaiArticleSection[]
}

model GakusaiArticleSection {
  id           String   @id @default(cuid())
  articleId    String
  heading      String
  content      String
  imageUrl     String? // セクション用の写真（任意）
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article GakusaiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
}
